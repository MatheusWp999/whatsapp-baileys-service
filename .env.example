PORT=3000
NODE_ENV=production
LOG_LEVEL=info
API_TOKEN=change-me

# Folder for Baileys auth state (must be persisted)
BAILEYS_SESSION_DIR=/data/sessions
BAILEYS_INSTANCE_PREFIX=crm-

# Optional Supabase persistence
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Message retention
WHATSAPP_LINKED_RETENTION_DAYS=90
WHATSAPP_UNLINKED_RETENTION_HOURS=24
